      "type": "stat",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "tms-postgres"},
        "rawSql": "SELECT COALESCE(SUM(CASE WHEN t='i' THEN m ELSE -m END),0) as value FROM (SELECT monto as m, 'i' as t FROM ingresos_ingreso WHERE DATE_TRUNC('month', fecha) = DATE_TRUNC('month', CURRENT_DATE) UNION ALL SELECT monto, 'g' FROM ingresos_gasto WHERE DATE_TRUNC('month', fecha) = DATE_TRUNC('month', CURRENT_DATE)) x",
