      "title": "Ingresos vs Gastos — Últimos 12 meses",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "tms-postgres"},
          "rawSql": "SELECT DATE_TRUNC('month', fecha) as time, SUM(monto) as Ingresos FROM ingresos_ingreso WHERE fecha >= NOW() - INTERVAL '12 months' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {"type": "postgres", "uid": "tms-postgres"},
          "rawSql": "SELECT DATE_TRUNC('month', fecha) as time, SUM(monto) as Gastos FROM ingresos_gasto WHERE fecha >= NOW() - INTERVAL '12 months' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "postgres", "uid": "tms-postgres"},
      "fieldConfig": {"defaults": {"unit": "locale"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "right"}, "pieType": "donut"},
      "title": "Gastos por categoría — Mes actual",
      "type": "piechart",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "tms-postgres"},
        "rawSql": "SELECT categoria as metric, SUM(monto) as value FROM ingresos_gasto WHERE DATE_TRUNC('month', fecha) = DATE_TRUNC('month', CURRENT_DATE) GROUP BY categoria ORDER BY value DESC",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "postgres", "uid": "tms-postgres"},
      "fieldConfig": {"defaults": {"unit": "locale"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Top 10 clientes por ingreso — Año actual",
      "type": "bargauge",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "tms-postgres"},
        "rawSql": "SELECT c.razon_social as metric, SUM(i.monto) as value FROM ingresos_ingreso i JOIN clientes_cliente c ON i.cliente_id = c.id WHERE EXTRACT(YEAR FROM i.fecha) = EXTRACT(YEAR FROM CURRENT_DATE) GROUP BY c.razon_social ORDER BY value DESC LIMIT 10",
        "format": "table",
        "refId": "A"
      }]
    },
    {
      "datasource": {"type": "postgres", "uid": "tms-postgres"},
      "fieldConfig": {
        "defaults": {"unit": "locale"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Ganancia"}, "properties": [{"id": "custom.displayMode", "value": "color-background"}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"footer": {"show": true, "reducer": ["sum"], "fields": ["Ingresos", "Gastos"]}, "showHeader": true},
      "title": "Rentabilidad por ruta",
      "type": "table",
      "targets": [{
        "datasource": {"type": "postgres", "uid": "tms-postgres"},
        "rawSql": "SELECT CONCAT(v.origen, ' → ', v.destino) as Ruta, COUNT(v.id) as Viajes, COALESCE(SUM(i.monto),0) as Ingresos, COALESCE(SUM(g.monto),0) as Gastos, COALESCE(SUM(i.monto),0) - COALESCE(SUM(g.monto),0) as Ganancia FROM viajes_viaje v LEFT JOIN ingresos_ingreso i ON i.viaje_id = v.id LEFT JOIN ingresos_gasto g ON g.viaje_id = v.id WHERE v.estado = 'finalizado' GROUP BY 1 ORDER BY Ganancia DESC LIMIT 20",
        "format": "table",
        "refId": "A"
      }]
    }
