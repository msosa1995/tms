# ============================================================
# TMS — Variables de entorno
# Copiar como .env y ajustar valores antes de levantar
# ============================================================

# Django
DEBUG=False
SECRET_KEY=cambiar-por-clave-segura-de-50-caracteres-minimo
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=tms_project.settings.production

# Base de datos
POSTGRES_DB=tms_db
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=cambiar_password_db
DATABASE_URL=postgresql://tms_user:cambiar_password_db@db:5432/tms_db

# Redis
REDIS_PASSWORD=cambiar_password_redis
REDIS_URL=redis://:cambiar_password_redis@redis:6379/0
CELERY_BROKER_URL=redis://:cambiar_password_redis@redis:6379/1
CELERY_RESULT_BACKEND=redis://:cambiar_password_redis@redis:6379/2

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=cambiar_password_grafana

# Frontend
VITE_API_URL=http://localhost/api
VITE_APP_NAME=TMS Transporte

# Email (para alertas)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=correo@empresa.com
EMAIL_HOST_PASSWORD=app_password_gmail

# Seguridad
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# Moneda principal
DEFAULT_CURRENCY=PYG
